<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PG Rent Management</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root {
            --primary-bg: #0d0d1a;
            --card-bg: #1a1a2e;
            --accent-glow: #00ffdd;
            --text-color: #e0e0e0;
            --input-border: #3a3a5e;
            --button-bg: #00ffdd;
            --button-text: #0d0d1a;
            --success-color: #4CAF50;
            --error-color: #F44336;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--primary-bg);
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: flex-start; /* Align items to the top initially */
            min-height: 100vh;
            overflow-x: hidden;
            box-sizing: border-box;
            position: relative;
        }

        canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }

        .container {
            width: 90%;
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
            background-color: var(--card-bg);
            border-radius: 15px;
            box-shadow: 0 0 30px rgba(0, 255, 221, 0.2);
            position: relative;
            z-index: 1;
            animation: fadeIn 1s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1, h2, h3 {
            color: var(--accent-glow);
            text-align: center;
            text-shadow: 0 0 10px rgba(0, 255, 221, 0.7);
            margin-bottom: 25px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-color);
            font-weight: bold;
            text-shadow: 0 0 5px rgba(0, 255, 221, 0.3);
        }

        input[type="text"],
        input[type="password"],
        input[type="number"],
        select {
            width: calc(100% - 20px);
            padding: 12px;
            background-color: #2a2a40;
            border: 1px solid var(--input-border);
            border-radius: 8px;
            color: var(--text-color);
            box-shadow: inset 0 0 8px rgba(0, 255, 221, 0.1);
            transition: all 0.3s ease;
        }

        input[type="text"]:focus,
        input[type="password"]:focus,
        input[type="number"]:focus,
        select:focus {
            outline: none;
            border-color: var(--accent-glow);
            box-shadow: 0 0 15px rgba(0, 255, 221, 0.5);
        }

        button {
            display: block;
            width: 100%;
            padding: 15px;
            background-color: var(--button-bg);
            color: var(--button-text);
            border: none;
            border-radius: 8px;
            font-size: 1.1em;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 0 10px rgba(0, 255, 221, 0.5);
        }

        button:hover {
            box-shadow: 0 0 25px rgba(0, 255, 221, 0.8);
            transform: translateY(-2px);
            background-color: var(--accent-glow);
            color: var(--primary-bg); /* Darker text on hover */
        }

        .message {
            margin-top: 20px;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            font-weight: bold;
            opacity: 0;
            transform: translateY(10px);
            animation: slideInMessage 0.5s forwards;
        }

        @keyframes slideInMessage {
            to { opacity: 1; transform: translateY(0); }
        }

        .message.success {
            background-color: rgba(76, 175, 80, 0.2);
            color: var(--success-color);
            border: 1px solid var(--success-color);
        }

        .message.error {
            background-color: rgba(244, 67, 54, 0.2);
            color: var(--error-color);
            border: 1px solid var(--error-color);
        }

        /* Rent Statement Card */
        .rent-statement-card {
            background-color: var(--card-bg);
            border-radius: 15px;
            box-shadow: 0 0 30px rgba(0, 255, 221, 0.2);
            padding: 30px;
            margin-top: 30px;
            animation: fadeIn 1s ease-out;
            border: 1px solid rgba(0, 255, 221, 0.4);
        }

        .rent-statement-card h2 {
            margin-top: 0;
            text-align: left;
            border-bottom: 2px solid rgba(0, 255, 221, 0.5);
            padding-bottom: 10px;
        }

        .statement-detail {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px dashed #3a3a5e;
        }

        .statement-detail:last-of-type {
            border-bottom: none;
        }

        .statement-detail span:first-child {
            font-weight: bold;
            color: var(--text-color);
        }

        .statement-detail span:last-child {
            color: var(--accent-glow);
            text-shadow: 0 0 5px rgba(0, 255, 221, 0.3);
        }

        .total-due {
            font-size: 1.3em;
            font-weight: bold;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 2px solid rgba(0, 255, 221, 0.5);
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--accent-glow);
        }

        .payment-status-badge {
            display: inline-block;
            padding: 8px 15px;
            border-radius: 20px;
            font-weight: bold;
            margin-left: 15px;
            text-shadow: 0 0 5px rgba(0, 0, 0, 0.5);
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
            text-transform: uppercase;
            font-size: 0.9em;
        }

        .payment-status-badge.paid {
            background-color: #4CAF50; /* Green */
            color: #fff;
        }
        .payment-status-badge.pending {
            background-color: #FFC107; /* Orange */
            color: #333;
        }
        .payment-status-badge.overdue {
            background-color: #F44336; /* Red */
            color: #fff;
        }

        /* Admin Dashboard */
        .admin-dashboard {
            display: grid;
            gap: 30px;
            margin-top: 30px;
        }

        .admin-section {
            background-color: var(--card-bg);
            border-radius: 15px;
            box-shadow: 0 0 30px rgba(0, 255, 221, 0.2);
            padding: 30px;
            border: 1px solid rgba(0, 255, 221, 0.4);
        }

        .admin-section h2 {
            text-align: left;
            border-bottom: 2px solid rgba(0, 255, 221, 0.5);
            padding-bottom: 10px;
            margin-top: 0;
            font-size: 1.8em;
        }

        .admin-section label {
            margin-top: 15px;
        }

        .admin-section button {
            margin-top: 25px;
        }

        /* Table styles */
        .table-container {
            margin-top: 30px;
            overflow-x: auto;
            max-height: 500px;
            border-radius: 10px;
            border: 1px solid rgba(0, 255, 221, 0.4);
            box-shadow: 0 0 20px rgba(0, 255, 221, 0.1);
        }

        .tenant-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 800px; /* Ensure table doesn't get too small */
        }

        .tenant-table th, .tenant-table td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid #3a3a5e;
        }

        .tenant-table th {
            background-color: rgba(0, 255, 221, 0.1);
            color: var(--accent-glow);
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            position: sticky;
            top: 0;
            z-index: 2;
        }

        .tenant-table tr:hover {
            background-color: #2a2a40;
            box-shadow: inset 0 0 10px rgba(0, 255, 221, 0.1);
        }

        .search-filter {
            margin-bottom: 20px;
        }

        .search-filter input {
            width: calc(100% - 20px);
            padding: 12px;
            background-color: #2a2a40;
            border: 1px solid var(--input-border);
            border-radius: 8px;
            color: var(--text-color);
            box-shadow: inset 0 0 8px rgba(0, 255, 221, 0.1);
            transition: all 0.3s ease;
        }

        .search-filter input:focus {
            outline: none;
            border-color: var(--accent-glow);
            box-shadow: 0 0 15px rgba(0, 255, 221, 0.5);
        }

        /* Utility classes */
        .hidden {
            display: none !important;
        }

        /* Loading Spinner */
        .spinner {
            border: 4px solid rgba(0, 255, 221, 0.3);
            border-top: 4px solid var(--accent-glow);
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
            display: none; /* Hidden by default */
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .spinner.active {
            display: block;
        }

        /* Media Queries for Responsiveness */
        @media (max-width: 768px) {
            .container {
                width: 95%;
                margin: 20px auto;
                padding: 15px;
            }

            h1 {
                font-size: 1.8em;
            }

            .admin-dashboard {
                grid-template-columns: 1fr;
            }

            .statement-detail span {
                font-size: 0.9em;
            }

            .payment-status-badge {
                padding: 6px 10px;
                font-size: 0.8em;
            }

            .total-due {
                font-size: 1.1em;
            }
        }

        @media (max-width: 480px) {
            h1 {
                font-size: 1.5em;
            }
            .statement-detail {
                flex-direction: column;
                align-items: flex-start;
            }
            .statement-detail span:last-child {
                margin-top: 5px;
            }
            .total-due {
                flex-direction: column;
                align-items: flex-start;
            }
            .payment-status-badge {
                margin-left: 0;
                margin-top: 10px;
            }
        }

        /* PDF styling for dark theme */
        .pdf-content {
            background-color: var(--card-bg) !important;
            color: var(--text-color) !important;
            padding: 30px;
            border-radius: 15px;
            box-shadow: none !important; /* Remove shadows for PDF */
        }
        .pdf-content h2, .pdf-content h3 {
            color: var(--accent-glow) !important;
            text-shadow: none !important;
            border-color: rgba(0, 255, 221, 0.5) !important;
        }
        .pdf-content .statement-detail {
            border-color: #3a3a5e !important;
        }
        .pdf-content .total-due {
            border-color: rgba(0, 255, 221, 0.5) !important;
            color: var(--accent-glow) !important;
        }
        .pdf-content .payment-status-badge.paid {
            background-color: #4CAF50 !important;
            color: #fff !important;
        }
        .pdf-content .payment-status-badge.pending {
            background-color: #FFC107 !important;
            color: #333 !important;
        }
        .pdf-content .payment-status-badge.overdue {
            background-color: #F44336 !important;
            color: #fff !important;
        }
        /* Ensure all text is visible on dark PDF */
        .pdf-content span, .pdf-content p, .pdf-content div {
            color: var(--text-color) !important;
        }

    </style>
</head>
<body>
    <canvas id="neonCanvas"></canvas>
    <div class="container" id="app">
        <h1 id="mainTitle">PG Rent Management</h1>

        <!-- Tenant Login / Rent Statement View -->
        <div id="tenantView">
            <div id="tenantLoginForm" class="active">
                <h2>Tenant Login</h2>
                <form id="mobileLoginForm">
                    <div class="form-group">
                        <label for="tenantMobile">Enter Registered Mobile Number:</label>
                        <input type="number" id="tenantMobile" required placeholder="e.g., 9876543210">
                    </div>
                    <button type="submit">View Rent Statement</button>
                </form>
                <div id="loginMessage" class="message hidden"></div>
                <div class="spinner" id="tenantSpinner"></div>
            </div>

            <div id="rentStatementDisplay" class="hidden">
                <div class="rent-statement-card" id="rentStatementCardContent">
                    <h2>Rent Statement</h2>
                    <div class="statement-detail"><span id="propNameLabel">Property Name:</span> <span id="propertyName"></span></div>
                    <div class="statement-detail"><span id="tenantNameLabel">Tenant Name:</span> <span id="tenantName"></span></div>
                    <div class="statement-detail"><span id="roomNumLabel">Room Number:</span> <span id="roomNumber"></span></div>
                    <div class="statement-detail"><span id="monthlyRentLabel">Monthly Rent:</span> <span id="monthlyRent"></span></div>
                    <div class="statement-detail"><span id="elecChargeLabel">Electricity Charges:</span> <span id="electricityCharges"></span></div>
                    <div class="statement-detail"><span id="securityDepLabel">Security Deposit:</span> <span id="securityDeposit"></span></div>
                    <div class="statement-detail"><span id="dueDateLabel">Due Date:</span> <span id="dueDate"></span></div>
                    <div class="total-due">
                        <span>Total Due: <span id="totalDue"></span></span>
                        <span id="paymentStatusBadge" class="payment-status-badge"></span>
                    </div>
                </div>
                <button id="downloadPdfBtn" style="margin-top: 30px;">Download Rent Statement as PDF</button>
                <button id="backToTenantLogin" style="margin-top: 15px; background-color: #3a3a5e; box-shadow: none;">Back to Login</button>
            </div>
        </div>

        <!-- Admin View -->
        <div id="adminView" class="hidden">
            <div id="adminLoginForm">
                <h2>Owner Login</h2>
                <form id="ownerLoginForm">
                    <div class="form-group">
                        <label for="adminPassword">Password:</label>
                        <input type="password" id="adminPassword" required placeholder="Enter Owner Password">
                    </div>
                    <button type="submit">Login</button>
                </form>
                <div id="ownerLoginMessage" class="message hidden"></div>
            </div>

            <div id="adminDashboard" class="hidden">
                <h2>Owner Dashboard</h2>
                <div class="admin-dashboard">
                    <div class="admin-section">
                        <h2>Add New Tenant</h2>
                        <form id="addTenantForm">
                            <div class="form-group">
                                <label for="newMobileNumber">Mobile Number:</label>
                                <input type="number" id="newMobileNumber" required placeholder="Tenant Mobile Number">
                            </div>
                            <div class="form-group">
                                <label for="newTenantName">Tenant Name:</label>
                                <input type="text" id="newTenantName" required placeholder="Tenant Full Name">
                            </div>
                            <div class="form-group">
                                <label for="newPropertyName">Property Name:</label>
                                <input type="text" id="newPropertyName" required placeholder="PG Name / Property Name">
                            </div>
                            <div class="form-group">
                                <label for="newRoomNumber">Room Number:</label>
                                <input type="text" id="newRoomNumber" required placeholder="Room number (e.g., A101)">
                            </div>
                            <div class="form-group">
                                <label for="newMonthlyRent">Monthly Rent:</label>
                                <input type="number" id="newMonthlyRent" required placeholder="Monthly Rent Amount">
                            </div>
                            <div class="form-group">
                                <label for="newElectricityCharges">Electricity Charges:</label>
                                <input type="number" id="newElectricityCharges" value="0" placeholder="Electricity charges (optional)">
                            </div>
                            <div class="form-group">
                                <label for="newSecurityDeposit">Security Deposit:</label>
                                <input type="number" id="newSecurityDeposit" value="0" placeholder="Security Deposit Amount">
                            </div>
                            <div class="form-group">
                                <label for="newTotalDue">Total Due:</label>
                                <input type="number" id="newTotalDue" required placeholder="Total Amount Due">
                            </div>
                            <div class="form-group">
                                <label for="newPaymentStatus">Payment Status:</label>
                                <select id="newPaymentStatus" required>
                                    <option value="Pending">Pending</option>
                                    <option value="Paid">Paid</option>
                                    <option value="Overdue">Overdue</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="newDueDate">Due Date:</label>
                                <input type="date" id="newDueDate" required>
                            </div>
                            <button type="submit">Add Tenant</button>
                        </form>
                        <div id="addTenantMessage" class="message hidden"></div>
                        <div class="spinner" id="addTenantSpinner"></div>
                    </div>

                    <div class="admin-section">
                        <h2>View All Tenants</h2>
                        <div class="search-filter">
                            <input type="text" id="tenantSearch" placeholder="Search by Mobile Number or Tenant Name...">
                        </div>
                        <div class="spinner" id="viewTenantsSpinner"></div>
                        <div class="table-container">
                            <table class="tenant-table">
                                <thead>
                                    <tr>
                                        <th>Mobile No.</th>
                                        <th>Tenant Name</th>
                                        <th>Property</th>
                                        <th>Room</th>
                                        <th>Rent</th>
                                        <th>Electricity</th>
                                        <th>Deposit</th>
                                        <th>Total Due</th>
                                        <th>Status</th>
                                        <th>Due Date</th>
                                    </tr>
                                </thead>
                                <tbody id="tenantTableBody">
                                    <!-- Tenant data will be loaded here -->
                                </tbody>
                            </table>
                        </div>
                        <div id="viewTenantsMessage" class="message hidden"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- Configuration ---
        const SHEET_ID = "1JH30u9RI5xvvWgbSRFAOEpNpenqJe2U6l0Hhr-OXrgs";
        const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzwSicVgcVsZ9QjaBBWoGkZzuPshUpeKPDhTTlwwrq2wOc2i5QaHddQyrG-UAPD-hAZGQ/exec";
        const ADMIN_PASSWORD = "admin123"; // Default admin password

        // --- DOM Elements ---
        const app = document.getElementById('app');
        const tenantView = document.getElementById('tenantView');
        const tenantLoginForm = document.getElementById('tenantLoginForm');
        const mobileLoginForm = document.getElementById('mobileLoginForm');
        const tenantMobileInput = document.getElementById('tenantMobile');
        const loginMessage = document.getElementById('loginMessage');
        const tenantSpinner = document.getElementById('tenantSpinner');

        const rentStatementDisplay = document.getElementById('rentStatementDisplay');
        const rentStatementCardContent = document.getElementById('rentStatementCardContent');
        const propertyName = document.getElementById('propertyName');
        const tenantName = document.getElementById('tenantName');
        const roomNumber = document.getElementById('roomNumber');
        const monthlyRent = document.getElementById('monthlyRent');
        const electricityCharges = document.getElementById('electricityCharges');
        const securityDeposit = document.getElementById('securityDeposit');
        const totalDue = document.getElementById('totalDue');
        const paymentStatusBadge = document.getElementById('paymentStatusBadge');
        const dueDate = document.getElementById('dueDate');
        const downloadPdfBtn = document.getElementById('downloadPdfBtn');
        const backToTenantLogin = document.getElementById('backToTenantLogin');


        const adminView = document.getElementById('adminView');
        const adminLoginForm = document.getElementById('adminLoginForm');
        const ownerLoginForm = document.getElementById('ownerLoginForm');
        const adminPasswordInput = document.getElementById('adminPassword');
        const ownerLoginMessage = document.getElementById('ownerLoginMessage');

        const adminDashboard = document.getElementById('adminDashboard');
        const addTenantForm = document.getElementById('addTenantForm');
        const addTenantMessage = document.getElementById('addTenantMessage');
        const addTenantSpinner = document.getElementById('addTenantSpinner');
        const tenantSearchInput = document.getElementById('tenantSearch');
        const tenantTableBody = document.getElementById('tenantTableBody');
        const viewTenantsSpinner = document.getElementById('viewTenantsSpinner');
        const viewTenantsMessage = document.getElementById('viewTenantsMessage');


        // --- Helper Functions ---
        function showMessage(element, message, type) {
            element.textContent = message;
            element.className = `message ${type}`;
            element.classList.remove('hidden');
            setTimeout(() => {
                element.classList.add('hidden');
            }, 5000); // Hide after 5 seconds
        }

        function showSpinner(spinnerElement) {
            spinnerElement.classList.add('active');
        }

        function hideSpinner(spinnerElement) {
            spinnerElement.classList.remove('active');
        }

        function getQueryParams() {
            const params = {};
            window.location.search.substring(1).split('&').forEach(param => {
                const parts = param.split('=');
                if (parts.length === 2) {
                    params[decodeURIComponent(parts[0])] = decodeURIComponent(parts[1]);
                }
            });
            return params;
        }

        function formatDate(dateString) {
            if (!dateString) return 'N/A';
            try {
                const date = new Date(dateString);
                // Adjust for timezone differences if dateString is just 'YYYY-MM-DD'
                const userTimezoneOffset = date.getTimezoneOffset() * 60000;
                const correctedDate = new Date(date.getTime() + userTimezoneOffset);
                return correctedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
            } catch (e) {
                console.error("Error formatting date:", e);
                return dateString; // Return original if parsing fails
            }
        }

        // --- Google Sheets Gviz API (Read) ---
        async function fetchTenantData(mobileNumber = null) {
            showSpinner(tenantSpinner);
            hideMessage(loginMessage);

            let url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json`;
            if (mobileNumber) {
                // Assuming MobileNumber is in column A (index 0)
                url += `&tq=${encodeURIComponent(`SELECT * WHERE A = '${mobileNumber}'`)}`;
            }

            try {
                const response = await fetch(url);
                const text = await response.text();
                // Google's gviz JSON is a bit funky, need to parse it
                const jsonp = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
                const data = JSON.parse(jsonp);

                const columns = data.table.cols.map(col => col.label);
                const rows = data.table.rows.map(row => {
                    const rowData = {};
                    row.c.forEach((cell, i) => {
                        rowData[columns[i]] = cell ? (cell.f || cell.v) : ''; // Use formatted value 'f' if available, else 'v'
                    });
                    return rowData;
                });
                return rows;
            } catch (error) {
                console.error('Error fetching data from Google Sheets:', error);
                showMessage(loginMessage, 'Failed to fetch data. Please try again.', 'error');
                return [];
            } finally {
                hideSpinner(tenantSpinner);
            }
        }

        // --- Tenant View Logic ---
        mobileLoginForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const mobileNumber = tenantMobileInput.value.trim();
            if (!mobileNumber) {
                showMessage(loginMessage, 'Please enter a mobile number.', 'error');
                return;
            }

            const tenants = await fetchTenantData(mobileNumber);

            if (tenants.length > 0) {
                const tenant = tenants[0]; // Assuming mobile number is unique
                propertyName.textContent = tenant.PropertyName || 'N/A';
                tenantName.textContent = tenant.TenantName || 'N/A';
                roomNumber.textContent = tenant.RoomNumber || 'N/A';
                monthlyRent.textContent = `₹ ${tenant.MonthlyRent || '0'}`;
                electricityCharges.textContent = `₹ ${tenant.ElectricityCharges || '0'}`;
                securityDeposit.textContent = `₹ ${tenant.SecurityDeposit || '0'}`;
                totalDue.textContent = `₹ ${tenant.TotalDue || '0'}`;
                dueDate.textContent = formatDate(tenant.DueDate);

                const status = tenant.PaymentStatus || 'N/A';
                paymentStatusBadge.textContent = status;
                paymentStatusBadge.className = 'payment-status-badge';
                if (status === 'Paid') {
                    paymentStatusBadge.classList.add('paid');
                } else if (status === 'Pending') {
                    paymentStatusBadge.classList.add('pending');
                } else if (status === 'Overdue') {
                    paymentStatusBadge.classList.add('overdue');
                }

                tenantLoginForm.classList.add('hidden');
                rentStatementDisplay.classList.remove('hidden');
            } else {
                showMessage(loginMessage, 'No tenant found with this mobile number.', 'error');
                tenantLoginForm.classList.remove('hidden');
                rentStatementDisplay.classList.add('hidden');
            }
        });

        downloadPdfBtn.addEventListener('click', async () => {
            downloadPdfBtn.disabled = true;
            downloadPdfBtn.textContent = 'Generating PDF...';

            const originalBg = document.body.style.backgroundColor;
            document.body.style.backgroundColor = 'var(--primary-bg)'; // Ensure dark background for PDF capture

            // Create a temporary div to clone and style the content for PDF
            const tempPdfContainer = document.createElement('div');
            tempPdfContainer.className = 'pdf-content'; // Apply PDF specific styles
            tempPdfContainer.innerHTML = rentStatementCardContent.innerHTML;
            tempPdfContainer.style.width = rentStatementCardContent.offsetWidth + 'px'; // Maintain width
            tempPdfContainer.style.position = 'absolute';
            tempPdfContainer.style.left = '-9999px'; // Hide off-screen
            document.body.appendChild(tempPdfContainer);

            try {
                const canvas = await html2canvas(tempPdfContainer, {
                    scale: 2, // Increase scale for better resolution
                    useCORS: true,
                    backgroundColor: null, // Transparent background for capture
                });
                const imgData = canvas.toDataURL('image/png');

                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF({
                    orientation: 'portrait',
                    unit: 'px',
                    format: [canvas.width, canvas.height] // Use canvas dimensions for format
                });

                pdf.addImage(imgData, 'PNG', 0, 0, canvas.width, canvas.height);
                pdf.save("Rent_Statement.pdf");

            } catch (error) {
                console.error("Error generating PDF:", error);
                alert("Failed to generate PDF. Please try again.");
            } finally {
                document.body.style.backgroundColor = originalBg; // Restore original background
                document.body.removeChild(tempPdfContainer); // Remove temporary container
                downloadPdfBtn.disabled = false;
                downloadPdfBtn.textContent = 'Download Rent Statement as PDF';
            }
        });


        backToTenantLogin.addEventListener('click', () => {
            rentStatementDisplay.classList.add('hidden');
            tenantLoginForm.classList.remove('hidden');
            tenantMobileInput.value = '';
        });

        function hideMessage(element) {
            element.classList.add('hidden');
        }

        // --- Admin View Logic ---
        ownerLoginForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const password = adminPasswordInput.value;
            if (password === ADMIN_PASSWORD) {
                adminLoginForm.classList.add('hidden');
                adminDashboard.classList.remove('hidden');
                loadAllTenants(); // Load tenants when admin logs in
            } else {
                showMessage(ownerLoginMessage, 'Incorrect password.', 'error');
            }
        });

        // Add Tenant Form Submission
        addTenantForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            showSpinner(addTenantSpinner);
            hideMessage(addTenantMessage);

            const formData = {
                MobileNumber: document.getElementById('newMobileNumber').value,
                TenantName: document.getElementById('newTenantName').value,
                PropertyName: document.getElementById('newPropertyName').value,
                RoomNumber: document.getElementById('newRoomNumber').value,
                MonthlyRent: document.getElementById('newMonthlyRent').value,
                ElectricityCharges: document.getElementById('newElectricityCharges').value,
                SecurityDeposit: document.getElementById('newSecurityDeposit').value,
                TotalDue: document.getElementById('newTotalDue').value,
                PaymentStatus: document.getElementById('newPaymentStatus').value,
                DueDate: document.getElementById('newDueDate').value,
            };

            try {
                const response = await fetch(SCRIPT_URL, {
                    method: 'POST',
                    mode: 'no-cors', // Required for Google Apps Script Web App
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: new URLSearchParams(formData).toString(),
                });

                // Since mode is 'no-cors', response.ok will always be false,
                // and response.json() will fail. We rely on the Apps Script
                // to handle the data and we assume success for the frontend.
                // A real-world app might use a more complex callback or a different proxy.

                showMessage(addTenantMessage, 'Tenant added successfully!', 'success');
                addTenantForm.reset(); // Clear form
                loadAllTenants(); // Reload tenant table
            } catch (error) {
                console.error('Error adding tenant:', error);
                showMessage(addTenantMessage, 'Failed to add tenant. Please check your script URL and Sheet ID.', 'error');
            } finally {
                hideSpinner(addTenantSpinner);
            }
        });

        // Load All Tenants for Admin
        async function loadAllTenants() {
            showSpinner(viewTenantsSpinner);
            hideMessage(viewTenantsMessage);
            tenantTableBody.innerHTML = ''; // Clear existing table

            const tenants = await fetchTenantData(); // Fetch all tenants (no mobile filter)

            if (tenants.length > 0) {
                tenants.forEach(tenant => {
                    const row = tenantTableBody.insertRow();
                    row.innerHTML = `
                        <td>${tenant.MobileNumber || 'N/A'}</td>
                        <td>${tenant.TenantName || 'N/A'}</td>
                        <td>${tenant.PropertyName || 'N/A'}</td>
                        <td>${tenant.RoomNumber || 'N/A'}</td>
                        <td>₹ ${tenant.MonthlyRent || '0'}</td>
                        <td>₹ ${tenant.ElectricityCharges || '0'}</td>
                        <td>₹ ${tenant.SecurityDeposit || '0'}</td>
                        <td>₹ ${tenant.TotalDue || '0'}</td>
                        <td><span class="payment-status-badge ${tenant.PaymentStatus ? tenant.PaymentStatus.toLowerCase() : 'N/A'}">${tenant.PaymentStatus || 'N/A'}</span></td>
                        <td>${formatDate(tenant.DueDate)}</td>
                    `;
                });
            } else {
                showMessage(viewTenantsMessage, 'No tenants found in the sheet.', 'info');
            }
            hideSpinner(viewTenantsSpinner);
        }

        // Search Filter for Admin View
        tenantSearchInput.addEventListener('keyup', () => {
            const filter = tenantSearchInput.value.toLowerCase();
            const rows = tenantTableBody.querySelectorAll('tr');

            rows.forEach(row => {
                const mobileNumber = row.cells[0].textContent.toLowerCase();
                const tenantName = row.cells[1].textContent.toLowerCase();
                if (mobileNumber.includes(filter) || tenantName.includes(filter)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });


        // --- Canvas Particle Animation ---
        const canvas = document.getElementById('neonCanvas');
        const ctx = canvas.getContext('2d');
        let particles = [];
        const particleCount = 100;
        const maxRadius = 3;
        const minRadius = 1;
        const color = 'rgba(0, 255, 221, 0.7)'; // Accent glow color

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        class Particle {
            constructor(x, y, radius, dx, dy) {
                this.x = x;
                this.y = y;
                this.radius = radius;
                this.dx = dx;
                this.dy = dy;
                this.opacity = Math.random() * 0.5 + 0.3; // Random opacity
            }

            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2, false);
                ctx.shadowBlur = 10;
                ctx.shadowColor = color;
                ctx.fillStyle = `rgba(0, 255, 221, ${this.opacity})`;
                ctx.fill();
            }

            update() {
                if (this.x + this.radius > canvas.width || this.x - this.radius < 0) {
                    this.dx = -this.dx;
                }
                if (this.y + this.radius > canvas.height || this.y - this.radius < 0) {
                    this.dy = -this.dy;
                }

                this.x += this.dx;
                this.y += this.dy;

                this.draw();
            }
        }

        function initParticles() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                let radius = Math.random() * (maxRadius - minRadius) + minRadius;
                let x = Math.random() * (canvas.width - radius * 2) + radius;
                let y = Math.random() * (canvas.height - radius * 2) + radius;
                let dx = (Math.random() - 0.5) * 0.8; // Slower movement
                let dy = (Math.random() - 0.5) * 0.8;
                particles.push(new Particle(x, y, radius, dx, dy));
            }
        }

        function animateParticles() {
            requestAnimationFrame(animateParticles);
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (let i = 0; i < particles.length; i++) {
                particles[i].update();
            }
        }

        let mouse = {
            x: undefined,
            y: undefined
        };

        window.addEventListener('mousemove', (event) => {
            mouse.x = event.x;
            mouse.y = event.y;
        });

        // Add a subtle reactive effect to particles based on mouse position
        function animateParticlesWithMouse() {
            requestAnimationFrame(animateParticlesWithMouse);
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (let i = 0; i < particles.length; i++) {
                let p = particles[i];

                // Simple repulsion effect
                const distance = Math.sqrt(Math.pow(mouse.x - p.x, 2) + Math.pow(mouse.y - p.y, 2));
                if (distance < 100 && mouse.x !== undefined) {
                    const angle = Math.atan2(p.y - mouse.y, p.x - mouse.x);
                    const force = 100 / (distance + 1); // Inverse distance force
                    p.dx += Math.cos(angle) * 0.1 * force;
                    p.dy += Math.sin(angle) * 0.1 * force;
                }

                p.update();
            }
        }

        window.addEventListener('resize', () => {
            resizeCanvas();
            initParticles(); // Reinitialize particles on resize
        });

        // --- Initial Load ---
        document.addEventListener('DOMContentLoaded', () => {
            const queryParams = getQueryParams();

            if (queryParams.admin !== undefined) {
                tenantView.classList.add('hidden');
                adminView.classList.remove('hidden');
                mainTitle.textContent = "PG Rent Management - Owner Panel";
            } else {
                adminView.classList.add('hidden');
                tenantView.classList.remove('hidden');
                mainTitle.textContent = "PG Rent Management - Tenant Panel";
            }

            // Initialize canvas animation
            resizeCanvas();
            initParticles();
            animateParticlesWithMouse(); // Use the mouse-reactive animation
        });
    </script>
